# MT5 Demo Trading Agent - Configuration
# Copy this file to .env and fill in your values

# Path to your MetaTrader 5 terminal executable
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# SQLite database file path
DB_PATH=trading_agent.db

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Backend API settings
API_HOST=127.0.0.1
API_PORT=8000

# Gemini advisory settings
GEMINI_TIMEOUT_SECONDS=12
GEMINI_MAX_RETRIES=1

# Finnhub event ingestion
ENABLE_FINNHUB=true
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_TIMEOUT_SECONDS=8
FINNHUB_MAX_RETRIES=2

# Active market mode: indices + commodities only
ACTIVE_ASSET_CLASSES=Indices,Commodities,Stocks
ENABLED_SYMBOLS=
DISABLED_SYMBOLS=NATGAS,XNGUSD,NGAS,NG
SYMBOL_PROFILE_OVERRIDES={"US500":"indices","US100":"indices","US30":"indices","GER40":"indices","GOLD":"gold","WTI":"commodities","BRENT":"commodities"}

# Credential storage
SAVE_CREDENTIALS_BY_DEFAULT=false
REQUIRE_SECURE_CREDENTIAL_STORAGE=true

# DANGER: Set to true to allow live account trading (NOT RECOMMENDED)
# LIVE_TRADING_ENABLED=false
